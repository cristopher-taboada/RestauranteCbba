@page
@model RestauranteCbba.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-azulgrana">
                <div class="card-header text-center">
                    <h2 class="mb-0">🔐 Iniciar Sesión</h2>
                </div>
                <div class="card-body">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Email" class="control-label fw-bold text-dorado">📧 Correo Electrónico</label>
                            <input asp-for="Input.Email" class="form-control form-control-azulgrana" placeholder="ejemplo@correo.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Password" class="control-label fw-bold text-dorado">🔑 Contraseña</label>
                            <input asp-for="Input.Password" class="form-control form-control-azulgrana" placeholder="Ingresa tu contraseña" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <div class="checkbox">
                                <label asp-for="Input.RememberMe" class="text-white">
                                    <input asp-for="Input.RememberMe" />
                                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                            </div>
                        </div>

                        <div class="form-group text-center">
                            <button type="submit" class="btn btn-grana btn-lg w-100">✅ Iniciar Sesión</button>
                        </div>

                        <div class="text-center mt-3">
                            <a asp-page="./Register" class="text-dorado">📝 ¿No tienes cuenta? Regístrate aquí</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}