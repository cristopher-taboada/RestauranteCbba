@model IEnumerable<RestauranteCbba.Models.Producto>

@{
    ViewData["Title"] = "Inicio";
}

<div class="hero-azulgrana" style="min-height: 60vh; display: flex; align-items: center; justify-content: center; flex-direction: column;">
    <div class="container text-center">
        <div style="font-size: 6rem; margin-bottom: 20px;">🍽️</div>
        <h1 style="font-size: 4.5rem; font-weight: 900;">
            Restaurante <span class="dorado" style="color: #ffd700;">Cochabamba</span>
        </h1>
        <p class="lead" style="font-size: 1.8rem; font-weight: 300;">
            Sabores auténticos de <span style="color: #ffd700;">Bolivia</span>
        </p>
        <hr style="border-color: rgba(255,215,0,0.3); max-width: 300px; margin: 30px auto;">

        @if (User.Identity.IsAuthenticated)
        {
            <div style="margin-top: 30px;">
                <p style="font-size: 1.2rem; color: #aaccdd;">
                    ¡Bienvenido, <strong style="color: #ffd700;">@User.Identity.Name</strong>!
                </p>
                <div>
                    <a asp-controller="Mesas" asp-action="Index" class="btn btn-grana mt-3" style="font-size: 1.2rem; padding: 15px 50px; margin: 5px;">
                        🪑 Ver Mesas
                    </a>
                    <a asp-controller="Reservas" asp-action="Create" class="btn btn-azulgrana mt-3" style="font-size: 1.2rem; padding: 15px 50px; margin: 5px;">
                        📅 Nueva Reserva
                    </a>
                    <a asp-controller="Carrito" asp-action="Index" class="btn btn-dorado mt-3" style="font-size: 1.2rem; padding: 15px 50px; margin: 5px; background: #ffd700; color: #002244;">
                        🛒 Ver Carrito
                    </a>
                </div>
            </div>
        }
        else
        {
            <div style="margin-top: 30px;">
                <p style="font-size: 1.2rem; color: #aaccdd;">
                    Para acceder a nuestro restaurante, por favor inicia sesión o regístrate
                </p>
                <div style="margin-top: 20px;">
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-grana" style="font-size: 1.1rem; padding: 15px 40px; margin: 0 10px;">
                        🔑 Iniciar sesión
                    </a>
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-azulgrana" style="font-size: 1.1rem; padding: 15px 40px; margin: 0 10px;">
                        📝 Registrarse
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- PLATOS TÍPICOS (DESDE NEON) -->
<div class="container mt-5">
    <h2 class="titulo-azulgrana text-center" style="display: block; text-align: center; margin-bottom: 40px;">
        🍽️ Nuestros <span class="dorado" style="color: #ffd700;">Platos Típicos</span>
    </h2>
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var producto in Model)
            {
                <div class="col-md-4">
                    <div class="card card-azulgrana h-100">
                        <div class="card-header text-center">
                            <h3 class="mb-0">@producto.Nombre!</h3>
                        </div>
                        <div class="card-body text-center">
                            <p>@producto.Descripcion!</p>
                            <p><span style="color: #ffd700; font-weight: bold;">★ @producto.Categoria!</span></p>
                            <p><span style="font-size: 1.5rem; color: #ffd700;">Bs. @producto.Precio.ToString("0.00")</span></p>
                            <p><span style="color: #aaccdd;">Stock: @producto.Stock</span></p>
                        </div>
                        <div class="card-footer text-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                if (producto.Stock > 0)
                                {
                                    <a asp-controller="Carrito" asp-action="Agregar" asp-route-id="@producto.Id" class="btn btn-grana btn-sm">🛒 Agregar al Carrito</a>
                                }
                                else
                                {
                                    <span class="badge bg-danger">❌ AGOTADO</span>
                                }
                            }
                            else
                            {
                                <span class="text-white-50">Inicia sesión para pedir</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="text-white-50">No hay platos disponibles en este momento.</p>
            </div>
        }
    </div>
</div>