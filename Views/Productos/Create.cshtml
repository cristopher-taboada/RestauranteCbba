@model RestauranteCbba.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-azulgrana">
                <div class="card-header text-center" style="background: linear-gradient(135deg, #003366, #002244);">
                    <h3 class="mb-0 text-white">➕ Crear Nuevo Producto</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="fw-bold text-dorado">Nombre *</label>
                            <input asp-for="Nombre" class="form-control form-control-azulgrana" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="fw-bold text-dorado">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control form-control-azulgrana" rows="3"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Cantidad" class="fw-bold text-dorado">📦 Stock *</label>
                                <input asp-for="Cantidad" class="form-control form-control-azulgrana" type="number" min="0" />
                                <span asp-validation-for="Cantidad" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Precio" class="fw-bold text-dorado">💰 Precio *</label>
                                <input asp-for="Precio" class="form-control form-control-azulgrana" type="number" step="0.01" min="0.01" />
                                <span asp-validation-for="Precio" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Categoria" class="fw-bold text-dorado">📂 Categoría</label>
                                <input asp-for="Categoria" class="form-control form-control-azulgrana" />
                                <span asp-validation-for="Categoria" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check mt-4">
                                    <input asp-for="Activo" class="form-check-input" />
                                    <label asp-for="Activo" class="form-check-label text-white">✅ Activo</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <button type="submit" class="btn btn-grana">💾 Guardar</button>
                            <a asp-action="Index" class="btn btn-azulgrana">🔙 Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}