@model RestauranteCbba.Models.Reserva

@{
    ViewData["Title"] = "Eliminar Reserva";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-azulgrana">
                <div class="card-header text-center">
                    <h2 class="mb-0">❌ Eliminar Reserva</h2>
                </div>
                <div class="card-body">
                    <h3 class="text-danger">¿Estás seguro de eliminar esta reserva?</h3>
                    <dl class="row text-white">
                        <dt class="col-sm-4">Mesa</dt>
                        <dd class="col-sm-8">@Model.Mesa?.NumeroMesa</dd>

                        <dt class="col-sm-4">Fecha</dt>
                        <dd class="col-sm-8">@Model.FechaReserva.ToShortDateString()</dd>

                        <dt class="col-sm-4">Hora</dt>
                        <dd class="col-sm-8">@Model.HoraReserva</dd>

                        <dt class="col-sm-4">Personas</dt>
                        <dd class="col-sm-8">@Model.NumeroPersonas</dd>

                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8">@Model.Estado</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-danger btn-lg px-5">🗑️ Eliminar</button>
                            <a asp-action="Index" class="btn btn-azulgrana btn-lg px-4">🔙 Mis Reservas</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>