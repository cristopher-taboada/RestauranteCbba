<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Restaurante Cochabamba</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RestauranteCbba.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <!-- ===== FONDO AZULGRANA ===== -->
    <div style="background: linear-gradient(180deg, #002244 0%, #003366 30%, #1a3a5c 60%, #0a1a2e 100%); min-height: 100vh;">

        <!-- Barra superior de club -->
        <div style="background: linear-gradient(90deg, #002244, #a5002c 50%, #002244); padding: 6px 0; text-align: center; color: #ffd700; font-size: 12px; letter-spacing: 4px; font-weight: 700; border-bottom: 2px solid #ffd700;">
            ⚽ ★ RESTAURANTE COCHABAMBA ★ SABORES DE BOLIVIA ★ ⚽
        </div>

        <!-- Navbar -->
        <header>
            <nav class="navbar navbar-expand-sm navbar-dark" style="background: linear-gradient(135deg, #002244 0%, #003366 40%, #002244 100%); border-bottom: 3px solid #a5002c; box-shadow: 0 4px 20px rgba(0,0,0,0.6);">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="font-size: 1.8rem; letter-spacing: 1px;">
                        <span style="background: linear-gradient(135deg, #a5002c, #c90034); color: #ffd700; padding: 5px 12px; border-radius: 5px; margin-right: 10px; border: 2px solid #ffd700;">🍽️</span>
                        <span style="color: #ffd700;">Restaurante</span> <span style="color: white;">Cochabamba</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="padding: 10px 20px; border-radius: 5px; margin: 0 3px; transition: all 0.3s;">Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Mesas" asp-action="Index" style="padding: 10px 20px; border-radius: 5px; margin: 0 3px; transition: all 0.3s;">Mesas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Productos" asp-action="Index" style="padding: 10px 20px; border-radius: 5px; margin: 0 3px; transition: all 0.3s;">Menú</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Reservas" asp-action="Index" style="padding: 10px 20px; border-radius: 5px; margin: 0 3px; transition: all 0.3s;">Reservas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Reportes" asp-action="Index" style="padding: 10px 20px; border-radius: 5px; margin: 0 3px; transition: all 0.3s;">Reportes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Carrito" asp-action="Index" style="padding: 10px 20px; border-radius: 5px; margin: 0 3px; transition: all 0.3s;">🛒 Carrito</a>
                            </li>
                        </ul>
                        <!-- ===== MENÚ DE AUTENTICACIÓN (SIN _LoginPartial) ===== -->
                        <ul class="navbar-nav">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white fw-bold" asp-controller="Auth" asp-action="Logout" style="background: #a5002c; border-radius: 20px; padding: 8px 20px; border: 2px solid #ffd700;">
                                        🚪 Cerrar Sesión
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white fw-bold" asp-controller="Auth" asp-action="Login" style="background: linear-gradient(135deg, #003366, #002244); border-radius: 20px; padding: 8px 20px; border: 2px solid #ffd700;">
                                        🔐 Iniciar Sesión
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white fw-bold" asp-controller="Auth" asp-action="Register" style="background: linear-gradient(135deg, #a5002c, #c90034); border-radius: 20px; padding: 8px 20px; border: 2px solid #ffd700;">
                                        📝 Registrarse
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <!-- CONTENIDO PRINCIPAL -->
        <div class="container" style="margin-top: 30px; margin-bottom: 30px; background: transparent;">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <!-- Footer -->
        <footer style="background: linear-gradient(135deg, #002244 0%, #003366 50%, #002244 100%); border-top: 3px solid #a5002c; color: white !important; padding: 25px 0; margin-top: 40px;">
            <div class="container text-center">
                <div style="font-size: 14px; letter-spacing: 3px; margin-bottom: 10px;">
                    <span style="color: #ffd700;">✦</span>
                    <span style="color: #ffd700; font-weight: 700;">RESTAURANTE COCHABAMBA</span>
                    <span style="color: #ffd700;">✦</span>
                </div>
                <div style="font-size: 12px; opacity: 0.8; color: #aaccdd;">
                    © 2026 - Sabores de Bolivia - Todos los derechos reservados
                </div>
                <div style="font-size: 11px; margin-top: 10px; opacity: 0.6; color: #aaccdd;">
                    Hecho con ❤️ en Cochabamba
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>