@{
    ViewData["Title"] = "Finalizar Compra";
    var total = ViewBag.Total ?? 0;
}

<h1 class="titulo-azulgrana">📋 Finalizar Compra</h1>
<p class="text-white-50">Completa los datos para tu pedido</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card card-azulgrana">
    <div class="card-body">
        <form asp-action="ConfirmarPedido" method="post">
            <div class="mb-3">
                <label class="fw-bold text-dorado">📍 Dirección de envío *</label>
                <input type="text" name="direccion" class="form-control form-control-azulgrana" placeholder="Calle, número, zona" required />
            </div>

            <div class="mb-3">
                <label class="fw-bold text-dorado">💳 Método de pago *</label>
                <select name="metodoPago" class="form-control form-control-azulgrana" required>
                    <option value="">Selecciona un método</option>
                    <option value="Efectivo">💵 Efectivo</option>
                    <option value="Tarjeta">💳 Tarjeta</option>
                    <option value="Transferencia">🏦 Transferencia</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="fw-bold text-dorado">💰 Total a pagar:</label>
                <p style="font-size: 1.5rem; color: #ffd700;">Bs. @total</p>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Carrito" class="btn btn-azulgrana">← Volver</a>
                <button type="submit" class="btn btn-grana">✅ Confirmar Pedido</button>
            </div>
        </form>
    </div>
</div>